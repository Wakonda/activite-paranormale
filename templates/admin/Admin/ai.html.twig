{% macro social_network(textarea, locale, text) %}

<div class="d-flex d-inline-flex mb-2">
<select id="ai_selector" class="form-select me-2">
	<option value="puter">Puter{% if isURLAvailable("https://js.puter.com/v2/") %} (unavailable){% endif %}</option>
	<option value="gemini">Gemini</option>
	<option value="cerebras">Cerebras</option>
</select>

<div id="puter_ai">
<div id="aiDropDownPuter{{ textarea }}" class="btn-group float-start me-1">
	<button type="button" id="generatePuter{{ textarea }}" class="btn btn-primary"><i class="fa-solid fa-robot" id="generate_icon_puter{{ textarea }}"></i></button>
	<button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
		<span class="visually-hidden">Toggle Dropdown</span>
	</button>
	<ul class="dropdown-menu">
		<li><a class="dropdown-item" href="#">gpt-4o-mini</a></li>
		<li><a class="dropdown-item" href="#">gpt-4o</a></li>
		<li><a class="dropdown-item" href="#">o3-mini</a></li>
		<li><a class="dropdown-item" href="#">o1-mini</a></li>
		<li><a class="dropdown-item" href="#">claude-3-7-sonnet</a></li>
		<li><a class="dropdown-item" href="#">claude-3-5-sonnet</a></li>
		<li><a class="dropdown-item" href="#">deepseek-chat</a></li>
		<li><a class="dropdown-item" href="#">deepseek-reasoner</a></li>
		<li><a class="dropdown-item" href="#">gemini-2.0-flash</a></li>
		<li><a class="dropdown-item" href="#">gemini-1.5-flash</a></li>
		<li><a class="dropdown-item" href="#">meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo</a></li>
		<li><a class="dropdown-item" href="#">meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo</a></li>
		<li><a class="dropdown-item" href="#">meta-llama/Meta-Llama-3.1-405B-Instruct-Turbo</a></li>
		<li><a class="dropdown-item" href="#">mistral-large-latest</a></li>
		<li><a class="dropdown-item" href="#">pixtral-large-latest</a></li>
		<li><a class="dropdown-item" href="#">codestral-latest</a></li>
		<li><a class="dropdown-item" href="#">google/gemma-2-27b-it</a></li>
		<li><a class="dropdown-item" href="#">grok-beta</a></li>
	</ul>
</div>
</div>

<script src="https://js.puter.com/v2/"></script>

<script>
	var model = "gpt-4o-mini";
	// https://docs.puter.com/playground/

	document.querySelectorAll('#aiDropDownPuter{{ textarea }} .dropdown-item').forEach(item => {
		item.addEventListener('click', (e) => {
			e.preventDefault();
			e.stopImmediatePropagation();
			model = e.srcElement.innerHTML;
			const dropdownToggle = document.querySelector('#aiDropDownPuter{{ textarea }} [data-bs-toggle="dropdown"]');
			const dropdown = bootstrap.Dropdown.getInstance(dropdownToggle);
			if (dropdown) dropdown.hide();
		});
	});

	document.getElementById("generatePuter{{ textarea }}").addEventListener("click", (e) => {
		let originalValue = document.getElementById('{{ textarea }}').value;
		document.getElementById("{{ textarea }}").value = "";
		e.preventDefault();
		document.querySelector("#generate_icon_puter{{ textarea }}").classList.remove("fa-robot");
		document.querySelector("#generate_icon_puter{{ textarea }}").classList.add("fa-arrows-rotate", "fa-spin");		

		(async () => {
			const textarea = document.getElementById('{{ textarea }}');
			const chat_resp = await puter.ai.chat('Language : {{ locale }}. Write a tweet on - ' + originalValue, { stream: true, model: model });
			let value = "";

			for await (const part of chat_resp) {
			console.log("ooo " + part?.text);
				value += part?.text;
				textarea.scrollTop = textarea.scrollHeight;
			}
			
			textarea.value = value.replace(/undefined$/, '');

			document.querySelector("#generate_icon_puter{{ textarea }}").classList.add("fa-robot");
			document.querySelector("#generate_icon_puter{{ textarea }}").classList.remove("fa-arrows-rotate", "fa-spin");
			
			if(document.getElementById("limit_string_{{ textarea }}") !== null)
				document.getElementById("limit_string_{{ textarea }}").innerHTML = limit - document.getElementById("{{ textarea }}").value.length;
		})();
	});
</script>

<div id="gemini_ai">
	<button type="button" id="generateGemini{{ textarea }}" class="btn btn-primary float-start me-1""><i class="fa-solid fa-spray-can-sparkles" id="generate_icon_gemini{{ textarea }}"></i></button>
</div>

<div id="cerebras_ai">
	<button type="button" id="generateCerebras{{ textarea }}" class="btn btn-primary float-start me-1""><i class="fa-solid fa-spray-can-sparkles" id="generate_icon_cerebras{{ textarea }}"></i></button>

</div>

	<script>
		function generateTextAI(type) {
			let originalValue = encodeURI(document.getElementById('{{ textarea }}').value);
			document.querySelector("#generate_icon_" + type + "{{ textarea }}").classList.remove("fa-spray-can-sparkles");
			document.querySelector("#generate_icon_" + type + "{{ textarea }}").classList.add("fa-arrows-rotate", "fa-spin");

			var xhr = new XMLHttpRequest();
			xhr.open("GET", "{{ path('Admin_AI') }}" + "?locale={{ locale }}&type=" + type + "&format=twitter&text=" + originalValue, true);

			xhr.onreadystatechange = function() {
				if (xhr.readyState === 4 && xhr.status === 200) {
					var data = JSON.parse(xhr.responseText);
					console.log(data);
					if (data.message) {
					console.log(data.message + "----------  {{ textarea }}  -----------")
						document.getElementById('{{ textarea }}').value = data.message.replaceAll('"', '');
					}

					document.querySelector("#generate_icon_" + type + "{{ textarea }}").classList.add("fa-spray-can-sparkles");
					document.querySelector("#generate_icon_" + type + "{{ textarea }}").classList.remove("fa-arrows-rotate", "fa-spin");
				}
			};

			xhr.send();
		}
	
		document.getElementById("generateGemini{{ textarea }}").addEventListener("click", (e) => {
			generateTextAI("gemini");
		});
	
		document.getElementById("generateCerebras{{ textarea }}").addEventListener("click", (e) => {
			generateTextAI("cerebras");
		});
	</script>


<script>

	document.getElementById("puter_ai").style.display = "block";
	document.getElementById("gemini_ai").style.display = "none";
	document.getElementById("cerebras_ai").style.display = "none";

document.querySelector('#ai_selector').addEventListener('change', (e) => {
	document.getElementById("puter_ai").style.display = "none";
	document.getElementById("gemini_ai").style.display = "none";
	document.getElementById("cerebras_ai").style.display = "none";
	if(e.target.value == "puter") {
		document.getElementById("puter_ai").style.display = "block";
	} else if(e.target.value == "gemini") {
		document.getElementById("gemini_ai").style.display = "block";
	} else if(e.target.value == "cerebras") {
		document.getElementById("cerebras_ai").style.display = "block";
	}
});
</script>
</div>
{% endmacro %}