{% if worldNews is not empty %}
	<h3>{{ "index.main.News"|trans([], "validators") }} <a href="{{ url('News_Index', {'page' : 1 }) }}" class="float-end text-info">{{ "generality.read.SeeAll"|trans([], "validators") }} <i class="fa-solid fa-arrow-right"></i></a></h3>
	{% for entity in worldNews %}
		{% if loop.first %}
			<div class="carousel-world-news-index">
				<div class="card mb-3">
					<div class="card-header h-100 text-start">
						<i class="fa-solid fa-star" style="color: darkorange;"></i> <span class="fw-bold" style="font-size: 16px;">{{ entity.title }}</span>
					</div>
					<div class=" g-0 card-body">
						{{ entity.photoIllustrationFilename|imgsize(null, entity.getAssetImagePath(), true, {loading: 'lazy', alt: entity.title, class: 'mx-auto d-block'})|raw }}

						<div class="text-center mt-3">
							<small class="text-white-50"><i class="fa-solid fa-calendar-days"></i> {{ entity.publicationDate|dodate(false, app.request.locale) }}</small>
						</div>

						<div class="mt-3">{{ entity.abstractText|raw }}</div>
					</div>
					<div class="card-footer h-100 text-start" style="border-top: 1px solid #bbc42d;">
						<div class="d-flex justify-content-between">
							<div><a class="btn btn-warning d-inline-block" href="{{ path('News_Index', {page: 1, theme: entity.theme.title }) }}"><i class="fas fa-dragon"></i> {{ entity.theme.title }}</a></div>
							<div><a class="btn read" href="{{ path('News_ReadNews_New', {'id': entity.id, 'title_slug':entity.getUrlSlug()}) }}"><i class="fas fa-book fa-fw"></i> {{ "news.slider.MoreDetails"|trans([], "validators") }}</a></div>
						</div>
					</div>
				</div>
			</div>
		{% endif %}
	{% endfor %}

	{% if worldNews > 1 %}
		<div id="news-container" class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 slider-container">
			{% for entity in worldNews %}
				{% if loop.first == false %}
					<div class="col">
						<div class="card h-100 d-flex flex-column">
							<div class="text-center d-block">
								<div class="news_embedded_image d-inline-block">
								{{ entity.photoIllustrationFilename|imgsize(null, entity.getAssetImagePath(), true, {loading: 'lazy', alt: entity.title})|raw }}
								</div>
							</div>
							<div class="card-body d-flex flex-column flex-grow-1">
								<h4 class="card-title text-center">{{ entity.title }}</h4>

								<div class="text-center mt-1">
									<small class="text-white-50"><i class="fa-solid fa-calendar-days"></i> {{ entity.publicationDate|dodate(false, app.request.locale) }}</small>
								</div>
								<div class="px-2">
									<hr>
								</div>
								{{ (entity.abstractText|raw)|truncate_words(200) }}

								<div class="mt-auto">
									<hr>
									<div class="d-flex flex-wrap-m gap-2">
										<a class="btn btn-warning w-100 w-md-auto" href="{{ path('News_Index', {page: 1, theme: entity.theme.title }) }}">
											<i class="fas fa-dragon"></i> {{ entity.theme.title }}
										</a>
										<a class="btn read w-100 w-md-auto" href="{{ path('News_ReadNews_New', {'id': entity.id, 'title_slug':entity.getUrlSlug()}) }}">
											<i class="fas fa-book fa-fw"></i> {{ "news.slider.MoreDetails"|trans([], "validators") }}
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				{% endif %}
			{% endfor %}
		</div>
	{% endif %}
{% endif %}