<a class="btn read w-100" href="{{ path('Store_Show', {'id': entity.id, 'title_slug': entity.slug}) }}">
	<i class="fas fa-book fa-fw"></i>
	{{ "store.search.Read"|trans([], "validators") }}
</a>
{% if entity.platform == constant('App\\Entity\\Stores\\Store::AMAZON_PLATFORM') %}
	<a class="btn amazon w-100" href="{{ entity.getExternalAmazonStoreLink() }}" rel="nofollow" target="_blank">
		<i class="fab fa-amazon fa-fw"></i>{{ "store.index.BuyOn"|trans([], "validators") }}
	</a>
{% elseif entity.platform == constant('App\\Entity\\Stores\\Store::ALIEXPRESS_PLATFORM') %}
	<a class="btn aliexpress w-100" href="{{ entity.url }}" rel="nofollow" target="_blank">
		<i class="fab fa-alipay fa-fw"></i>
		{{ "store.index.BuyOn"|trans([], "validators") }}
	</a>
{% elseif entity.platform == constant('App\\Entity\\Stores\\Store::TEMU_PLATFORM') %}
	<a class="btn temu text-white w-100" href="{{ entity.url }}" rel="nofollow" target="_blank">
		<i class="fa-solid fa-warehouse fa-fw"></i>
		{{ "store.index.BuyOn"|trans([], "validators") }}
	</a>
{% else %}
	<a class="btn spreadshop w-100" href="{{ entity.url }}" rel="nofollow" target="_blank">
		<i class="fas fa-cart-shopping fa-fw"></i>
		{{ "store.index.BuyOn"|trans([], "validators") }}
	</a>
{% endif %}